    background:#222;
    color:white;
    text-align:center;
    padding:20px;
}

.btn{
    display:inline-block;
    background:#f4b400;
    color:black;
    padding:12px 24px;
    border-radius:8px;
    text-decoration:none;
    font-weight:bold;
}

